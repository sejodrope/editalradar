# EditalRadar — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# O arquivo .env NUNCA deve ser commitado no repositório.

# ── Gemini AI (opcional) ──────────────────────────────────────────────────────
# Obtenha sua chave gratuita em: https://aistudio.google.com/
# Sem esta chave o app funciona normalmente, mas sem triagem automática de relevância.
GEMINI_API_KEY=""

# ── Banco de dados ────────────────────────────────────────────────────────────
# Caminho para o arquivo SQLite local (padrão: editalradar.db na raiz do projeto)
# DB_PATH="editalradar.db"

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Fuso horário usado pelo APScheduler
# TZ="America/Sao_Paulo"
